+def roc_write_to_csv(file_path, data, format):
+    time_cost = time.time()
+    if not type(data) is np.ndarray:
+        data = data.numpy()
+    np.savetxt(file_path, data, delimiter=',', fmt=format)
+
+    time_cost = time.time() - time_cost
+    print("write to {} is done, cost: {:.2f}s Throughput:{:.2f}MB/s".format(file_path, time_cost, os.path.getsize(file_path)/1024/1024/time_cost))
+
+def roc_edge_to_flux_csc(file_path, num_nodes, edge_list):
+    nbr = []
+    for i in range(num_nodes):
+        nbr.append([])
+ 
+    time_cost = time.time()
+    for e in edge_list:
+        nbr[e[1]].append(e[0])
+
+    with open(file_path, 'wb') as f:
+        # nv
+        # ne
+        f.write(np.array(num_nodes, dtype=np.uint32).tobytes())
+        f.write(np.array(len(edge_list), dtype=np.uint64).tobytes())
+        # write c
+        c_idx = 0
+        #f.write(np.array(c_idx, dtype=np.uint64).tobytes())
+        for i in range(num_nodes):
+            c_idx += len(nbr[i])  # node i has idx of i-1
+            f.write(np.array(c_idx, dtype=np.uint64).tobytes())
+        # write neighbors
+        for i in range(num_nodes):
+            nbr[i].sort()
+            sl = nbr[i]
+            if sl is not None and len(sl) > 0:
+                f.write(np.array(sl, dtype=np.uint32).tobytes())
+
+#    a = np.fromfile(file_path, dtype=np.uint32)
+#    b = np.fromfile(file_path, dtype=np.uint64)
+#    print(f"{num_nodes}, {len(edge_list)}")
+#    print(f"{a}")
+#    print(f"{b}")
+    time_cost = time.time() - time_cost
+    print("write to {} is done, cost: {:.2f}s Throughput:{:.2f}MB/s".format(file_path, time_cost, os.path.getsize(file_path)/1024/1024/time_cost))
+
+
+def generate_roc_dataset(args, edge_list, features, labels, train_mask, val_mask, test_mask):
+    dataset = args.dataset
+    #pre_path = os.getcwd() + '/roc_' + dataset
+    pre_path = '/data/roc/'
+    os.makedirs(pre_path, exist_ok=True)
+    pre_path = pre_path + dataset
+
+    # edgelist
+    # write_to_file(pre_path + '.edgelist', edge_list, "%d")
+
+    # edge_list binary format (gemini)
+    # edge2bin(pre_path + '.edge', edge_list)
+    roc_edge_to_flux_csc(pre_path + '.add_self_edge.lux', len(labels), edge_list)
+    # fetures
+    roc_write_to_csv(pre_path + '.feats.csv', features, "%.4f")
+
+    # label
+    roc_write_to_csv(pre_path + '.label', labels, "%d")
+
+    # mask
+    mask_list = []
+    for i in range(len(labels)):
+        if train_mask[i] == True:
+            mask_list.append('Train')
+        elif val_mask[i] == True:
+            mask_list.append('Val')
+        elif test_mask[i] == True:
+            mask_list.append('Test')
+        else:
+            mask_list.append('None')
+    roc_write_to_csv(pre_path + '.mask', np.array(mask_list), "%s")
 
