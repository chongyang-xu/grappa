 	} else {
-	  attr->isManaged = 0;
+	  //attr->isManaged = 0;
 	  switch(mtype) {
 	  case CU_MEMORYTYPE_HOST: {
-	    attr->memoryType = cudaMemoryTypeHost;
+	    //attr->memoryType = cudaMemoryTypeHost;
