 	    attr->type = cudaMemoryTypeHost;
 #endif
 	    break;
 	  }
 	  case CU_MEMORYTYPE_DEVICE: {
-	    attr->memoryType = cudaMemoryTypeDevice;
+	    //attr->memoryType = cudaMemoryTypeDevice;
 #if CUDART_VERSION >= 10000
 	    attr->type = cudaMemoryTypeDevice;
 #endif
